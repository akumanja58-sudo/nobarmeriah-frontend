# .env.example - Environment Variables for Auto Football System
# Copy this file to .env and fill in your actual values

# ============= via NobarMeriah CONFIGURATION =============
# Your via NobarMeriah API key (get from: https://www.api-football.com/)
REACT_APP_FOOTBALL_API_KEY=your_api_key_here

# API quota limits (75,000 per day for Ultra plan)
REACT_APP_DAILY_QUOTA=75000
REACT_APP_MONTHLY_QUOTA=2250000

# Rate limiting (milliseconds between requests)
REACT_APP_API_RATE_LIMIT=100

# ============= SUPABASE CONFIGURATION =============
# Your Supabase project URL
REACT_APP_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon public key
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key (for admin operations - keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ============= NOTIFICATION CONFIGURATION =============
# Webhook URL for external notifications (optional)
REACT_APP_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# Email service configuration (optional)
REACT_APP_EMAIL_SERVICE_API_KEY=your_email_api_key
REACT_APP_ADMIN_EMAIL=admin@yourdomain.com

# ============= SYSTEM CONFIGURATION =============
# Environment (development, staging, production)
NODE_ENV=development

# Application name
REACT_APP_NAME=Football Manager

# Application version
REACT_APP_VERSION=1.0.0

# ============= AUTO SYSTEM CONFIGURATION =============
# Enable/disable auto system on startup
REACT_APP_AUTO_START_SYSTEM=true

# Default sync intervals (minutes)
REACT_APP_DEFAULT_SYNC_INTERVAL=30
REACT_APP_LIVE_SYNC_INTERVAL=0.5
REACT_APP_STATUS_SYNC_INTERVAL=5

# Safety margins for API usage
REACT_APP_QUOTA_SAFETY_MARGIN=0.85

# Maximum retries for failed requests
REACT_APP_MAX_RETRIES=3

# ============= MONITORING CONFIGURATION =============
# Enable system monitoring
REACT_APP_ENABLE_MONITORING=true

# Log retention (days)
REACT_APP_LOG_RETENTION_DAYS=7

# Notification retention (days)
REACT_APP_NOTIFICATION_RETENTION_DAYS=30

# ============= SECURITY CONFIGURATION =============
# JWT secret for admin authentication
JWT_SECRET=your_super_secret_jwt_key_here

# Admin panel access
REACT_APP_ADMIN_PASSWORD=your_admin_password

# API request timeout (milliseconds)
REACT_APP_API_TIMEOUT=15000

# ============= LEAGUE CONFIGURATION =============
# Default season
REACT_APP_DEFAULT_SEASON=2025

# Maximum leagues to track simultaneously
REACT_APP_MAX_TRACKED_LEAGUES=50

# Priority league IDs (comma-separated)
REACT_APP_PRIORITY_LEAGUES=39,140,135,78,61,2,3

# ============= PERFORMANCE CONFIGURATION =============
# Database connection pool size
DATABASE_POOL_SIZE=10

# Cache TTL (seconds)
REACT_APP_CACHE_TTL=300

# Enable data compression
REACT_APP_ENABLE_COMPRESSION=true

# ============= FEATURE FLAGS =============
# Enable/disable specific features
REACT_APP_ENABLE_ODDS=true
REACT_APP_ENABLE_PLAYER_STATS=true
REACT_APP_ENABLE_TEAM_STATS=true
REACT_APP_ENABLE_LIVE_SCORES=true
REACT_APP_ENABLE_PREDICTIONS=false
REACT_APP_ENABLE_TRANSFERS=true
REACT_APP_ENABLE_INJURIES=true

# ============= DEVELOPMENT CONFIGURATION =============
# Enable debug mode
REACT_APP_DEBUG=false

# Enable verbose logging
REACT_APP_VERBOSE_LOGGING=false

# Mock API responses (for testing without API calls)
REACT_APP_MOCK_API=false

# ============= BACKUP CONFIGURATION =============
# Backup settings
REACT_APP_ENABLE_AUTO_BACKUP=true
REACT_APP_BACKUP_INTERVAL_HOURS=24
REACT_APP_BACKUP_RETENTION_DAYS=30

# ============= SOCIAL FEATURES =============
# Social media integration (optional)
REACT_APP_TWITTER_API_KEY=your_twitter_api_key
REACT_APP_FACEBOOK_API_KEY=your_facebook_api_key

# ============= ANALYTICS =============
# Analytics service (optional)
REACT_APP_GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
REACT_APP_MIXPANEL_TOKEN=your_mixpanel_token

# ============= CDN CONFIGURATION =============
# CDN for static assets (optional)
REACT_APP_CDN_URL=https://cdn.yourdomain.com
REACT_APP_IMAGES_CDN=https://images.yourdomain.com

# ============= TIMEZONE CONFIGURATION =============
# Default timezone for the application
REACT_APP_DEFAULT_TIMEZONE=Asia/Jakarta
REACT_APP_DISPLAY_TIMEZONE=Asia/Jakarta

# ============= LOCALIZATION =============
# Default language
REACT_APP_DEFAULT_LANGUAGE=en
REACT_APP_SUPPORTED_LANGUAGES=en,id,es,fr,de

# ============= CUSTOM LEAGUE SETTINGS =============
# Custom league configurations (JSON format)
REACT_APP_CUSTOM_LEAGUE_CONFIG={"39":{"priority":1,"sync_interval":5},"140":{"priority":1,"sync_interval":5}}

# ============= EXPERIMENTAL FEATURES =============
# Enable experimental features (use with caution)
REACT_APP_ENABLE_EXPERIMENTAL=false
REACT_APP_ENABLE_AI_PREDICTIONS=false
REACT_APP_ENABLE_REAL_TIME_CHAT=false

# ============= MAINTENANCE MODE =============
# Enable maintenance mode
REACT_APP_MAINTENANCE_MODE=false
REACT_APP_MAINTENANCE_MESSAGE="System under maintenance. Please check back later."

# ============= IMPORTANT NOTES =============
#
# 1. SECURITY REMINDERS:
#    - Never commit .env files to version control
#    - Keep your API keys secret
#    - Use strong passwords and JWT secrets
#    - Regularly rotate API keys
#
# 2. via NobarMeriah SETUP:
#    - Sign up at https://www.api-football.com/
#    - Choose the Ultra plan (75K requests/day)
#    - Get your API key from the dashboard
#    - Test your API key before going live
#
# 3. SUPABASE SETUP:
#    - Create a new project at https://supabase.com/
#    - Run the database schema from database_schema.sql
#    - Configure RLS policies
#    - Get your project URL and keys
#
# 4. MONITORING:
#    - Set up webhook for alerts
#    - Configure email notifications
#    - Monitor API usage regularly
#    - Set up log rotation
#
# 5. PERFORMANCE:
#    - Adjust sync intervals based on your needs
#    - Monitor database performance
#    - Use CDN for static assets
#    - Enable compression in production
#
# 6. DEPLOYMENT:
#    - Use different .env files for different environments
#    - Set appropriate NODE_ENV values
#    - Configure proper security headers
#    - Set up SSL certificates